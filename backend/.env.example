# AI Media Watch — engine configuration.
# Copy to ".env" and adjust. Every variable is optional; the defaults shown here
# match app/config.py. All names are prefixed with AMW_.

# --- Paths ------------------------------------------------------------------ #
# Root data directory (uploads + SQLite live under here by default).
AMW_DATA_DIR=./data
# Where uploaded videos / extracted artifacts are written.
AMW_UPLOAD_DIR=./data/uploads
# SQLite database file for analyzed cases.
AMW_DB_PATH=./data/cases.db

# --- Tiered cascade control ------------------------------------------------- #
# Cheap-lane score at/above which the heavy ML lanes are allowed to escalate.
AMW_ESCALATE_ABOVE=25.0
# Lower bound below which an upload still escalates (thin text is also a trigger).
AMW_SHORTCIRCUIT_BELOW=8.0

# --- Optional ML lanes (feature flags) -------------------------------------- #
# Set to false to force-skip a lane even when its dependencies are installed.
AMW_ENABLE_ASR=true
AMW_ENABLE_OCR=true
AMW_ENABLE_VISION=true

# --- Model selection -------------------------------------------------------- #
# Whisper / faster-whisper model size: tiny | base | small | medium | large-v3.
AMW_WHISPER_MODEL=base
# cpu | cuda
AMW_WHISPER_DEVICE=cpu
# open_clip model architecture + pretrained weights tag.
AMW_CLIP_MODEL=ViT-B-32
AMW_CLIP_PRETRAINED=openai
# Tesseract OCR language packs (e.g. "rus+eng").
AMW_TESSERACT_LANG=rus+eng

# --- Keyframe sampling (efficiency: sample, never full-decode) --------------- #
AMW_KEYFRAME_INTERVAL=2.0
AMW_MAX_KEYFRAMES=24
AMW_KEYFRAME_MAX_DIM=720

# --- Server ----------------------------------------------------------------- #
AMW_HOST=127.0.0.1
AMW_PORT=8000
# Maximum accepted upload size, in megabytes.
AMW_MAX_UPLOAD_MB=500
# Comma-separated CORS origins. Defaults to the Vite dev/preview ports.
AMW_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

# --- Custom learned risk model (app.ml) ------------------------------------- #
# Use the trained model when present (else the engine falls back to rules).
AMW_ML_ENABLE=true
# How the model score combines with the rule score: model | rules | blend.
AMW_ML_BLEND=blend
# Weight of the MODEL in the blend (0..1); rules get the remainder.
AMW_ML_BLEND_ALPHA=0.6
# Train with:  python -m app.ml.cli train   (regenerates data + fits on CPU)
